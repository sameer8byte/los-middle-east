{
    "name": "los-backend",
    "version": "1.0.0",
    "description": "Scalable loan application backend",
    "author": "",
    "private": true,
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "node --max_old_space_size=4096 --max-http-header-size=100000 dist/main.js",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "schema": "npx prisma db pull && npx prisma generate",
        "migrate:passwords": "ts-node scripts/migrate-passwords-to-bcrypt.ts",
        "test:bcrypt": "ts-node scripts/test-bcrypt.ts",
        "trigger:dev": "npx trigger.dev@4.0.2 dev",
        "trigger:deploy": "npx trigger.dev@4.0.2 deploy --log-level debug",
        "pm2:install": "npm install -g pm2",
        "pm2:start": "pm2 start ecosystem.config.js",
        "pm2:restart": "pm2 restart ecosystem.config.js",
        "pm2:stop": "pm2 stop ecosystem.config.js",
        "pm2:delete": "pm2 delete ecosystem.config.js",
        "pm2:logs": "pm2 logs",
        "pm2:logs:api": "pm2 logs los-backend-api",
        "pm2:logs:cron": "pm2 logs los-backend-cron-worker",
        "pm2:status": "pm2 status",
        "pm2:monit": "pm2 monit",
        "pm2:save": "pm2 save",
        "pm2:startup": "pm2 startup && pm2 save",
        "pm2:describe": "pm2 describe ecosystem.config.js",
        "pm2:reload": "pm2 reload los-backend-api"
    },
    "dependencies": {
        "@nestjs/axios": "^4.0.0",
        "@nestjs/common": "^10.4.17",
        "@nestjs/config": "^3.0.0",
        "@nestjs/core": "^10.2.1",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/jwt": "^10.1.0",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^10.2.1",
        "@nestjs/schedule": "^6.0.1",
        "@nestjs/throttler": "^4.2.1",
        "@prisma/client": "^6.15.0",
        "@sendgrid/mail": "^8.1.5",
        "@trigger.dev/sdk": "4.0.2",
        "@types/ioredis": "^4.28.10",
        "aws-sdk": "^2.1692.0",
        "axios": "^1.8.4",
        "bcrypt": "^5.1.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "compression": "^1.8.0",
        "cookie-parser": "^1.4.7",
        "crypto-js": "^4.2.0",
        "csv-writer": "^1.6.0",
        "dayjs": "^1.11.19",
        "decimal.js": "^10.5.0",
        "ejs": "^3.1.10",
        "exceljs": "^4.4.0",
        "express": "^5.1.0",
        "form-data": "^4.0.2",
        "google-auth-library": "^9.15.1",
        "helmet": "^7.0.0",
        "ioredis": "^5.8.2",
        "joi": "^17.9.2",
        "json-bigint": "^1.0.0",
        "json2csv": "^6.0.0-alpha.2",
        "moment": "^2.29.4",
        "playwright": "^1.52.0",
        "prisma-erd-generator": "^2.0.4",
        "puppeteer": "^23.11.1",
        "reflect-metadata": "^0.1.13",
        "rimraf": "^5.0.1",
        "rxjs": "^7.8.1",
        "twilio": "^5.5.2",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.1.12",
        "@nestjs/schematics": "^10.0.2",
        "@nestjs/testing": "^10.2.1",
        "@trigger.dev/build": "4.0.2",
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.10",
        "@types/crypto-js": "^4.2.2",
        "@types/ejs": "^3.1.5",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.4",
        "@types/json-bigint": "^1.0.4",
        "@types/json2csv": "^5.0.7",
        "@types/multer": "^1.4.7",
        "@types/node": "^20.5.7",
        "@types/serve-static": "^1.15.8",
        "@types/supertest": "^2.0.12",
        "@types/uuid": "^10.0.0",
        "@types/xml2js": "^0.4.14",
        "@typescript-eslint/eslint-plugin": "^6.5.0",
        "@typescript-eslint/parser": "^6.5.0",
        "eslint": "^8.48.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "i": "^0.3.7",
        "jest": "^29.6.4",
        "npm": "^11.3.0",
        "prettier": "^3.0.3",
        "prisma": "^6.15.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-loader": "^9.4.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.8.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
