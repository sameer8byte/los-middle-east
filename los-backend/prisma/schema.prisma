generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PartnerLoginToken {
  id            String      @id @default(uuid())
  partnerUserId String
  accessToken   String      @unique
  refreshToken  String      @unique
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deviceId      String?     @db.VarChar(255)
  isLoggedOut   Boolean?    @default(false)
  isLogoutAt    DateTime?
  partner_user  PartnerUser @relation("PartnerUserToLoginTokens", fields: [partnerUserId], references: [id], onDelete: Cascade)

  @@map("partner_login_tokens")
}

model PartnerRole {
  id            Int                     @id @default(autoincrement())
  name          String                  @unique
  description   String?
  role_group_id String?                 @db.VarChar(16)
  notifications notifications[]
  brandRoles    PartnerUserBrandRole[]
  globalRoles   PartnerUserGlobalRole[]

  @@map("partner_roles")
}

model PartnerUser {
  id                                 String                                @id @default(uuid())
  email                              String                                @unique
  password                           String
  createdAt                          DateTime                              @default(now())
  updatedAt                          DateTime
  name                               String?
  deletedAt                          DateTime?
  isActive                           Boolean                               @default(true)
  reportsToId                        String?
  isReloanSupport                    Boolean                               @default(false)
  old_id                             String?                               @db.VarChar(50)
  is_fresh_loan_support              Boolean                               @default(true)
  is_disabled                        Boolean                               @default(false)
  phone_number                       String?                               @db.VarChar(10)
  loanAllottedPartnerUsers           LoanAllottedPartnerUser[]
  loan_collection_allocated_partner  loan_collection_allocated_partner[]   @relation("PartnerUserToLoanCollections")
  loanStatusHistories                LoanStatusHistory[]                   @relation("PartnerUserToLoanStatusHistories")
  notification_targets               notification_targets[]
  createdNotifications               notifications[]
  onboardingJourneys                 OnboardingJourney[]
  loginTokens                        PartnerLoginToken[]                   @relation("PartnerUserToLoginTokens")
  unavailabilityDates                PartnerUnavailabilityDate[]           @relation("PartnerToUnavailabilityDates")
  activitySessions                   PartnerUserActivitySession[]          @relation("PartnerUserToActivitySessions")
  brandRoles                         PartnerUserBrandRole[]
  codeAuditLogs                      partner_user_code_audit_logs[]        @relation("PartnerUserToCodeAudits")
  performedCodeAudits                partner_user_code_audit_logs[]        @relation("PartnerUserPerformedCodeAudits")
  deactivatedCodes                   partner_user_codes[]                  @relation("PartnerUserDeactivatedCodes")
  generatedCodes                     partner_user_codes[]                  @relation("PartnerUserGeneratedCodes")
  partnerCodes                       partner_user_codes[]                  @relation("PartnerUserToCodes")
  globalRoles                        PartnerUserGlobalRole[]
  inactivityAlerts                   PartnerUserInactivityAlert[]          @relation("PartnerUserToInactivityAlerts")
  loginLogs                          PartnerUserLoginLog[]                 @relation("PartnerUserToLoginLogs")
  partner_user_password_reset_tokens PartnerUserPasswordResetToken[]
  userPermissions                    PartnerUserPermission[]
  primaryPermission                  PartnerUserPrimaryPermission?         @relation("PrimaryPermissionRelation")
  reportLogs                         PartnerUserReportLog[]                @relation("PartnerUserToReportLogs")
  partner_user_rules                 partner_user_rules?
  reportsTo                          PartnerUser?                          @relation("PartnerUserHierarchy", fields: [reportsToId], references: [id])
  subordinates                       PartnerUser[]                         @relation("PartnerUserHierarchy")
  createdAutopayTransactions         payment_autopay_transaction[]         @relation("PaymentAutopayTransactionCreatedBy")
  createdCollectionTransactions      PaymentCollectionTransaction[]        @relation("PaymentCollectionTransactionCreatedBy")
  opsCollectionTransactions          PaymentCollectionTransaction[]        @relation("PaymentCollectionTransactionOpsBy")
  createdDisbursalTransactions       PaymentDisbursalTransaction[]         @relation("PaymentDisbursalTransactionCreatedBy")
  opsDisbursalTransactions           PaymentDisbursalTransaction[]         @relation("PaymentDisbursalTransactionOpsBy")
  createdPartialTransactions         PaymentPartialCollectionTransaction[] @relation("PaymentPartialCollectionTransactionCreatedBy")
  opsPartialTransactions             PaymentPartialCollectionTransaction[] @relation("PaymentPartialCollectionTransactionOpsBy")
  repaymentTimelines                 RepaymentTimeline[]
  serviceRequestLogs                 ServiceRequestLog[]
  user_allotted_partner_user_logs    user_allotted_partner_user_logs[]
  userCalls                          UserCall[]

  @@index([isActive], map: "idx_partner_user_is_active")
  @@index([createdAt], map: "idx_partner_user_created_at")
  @@map("partner_users")
}

model PartnerUserLoginLog {
  id            String      @id @default(uuid())
  partnerUserId String
  date          DateTime    @db.Date
  firstLogin    DateTime
  lastLogout    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  partnerUser   PartnerUser @relation("PartnerUserToLoginLogs", fields: [partnerUserId], references: [id])

  @@unique([partnerUserId, date])
  @@index([partnerUserId, date], map: "idx_partner_login_log_partner_date")
  @@index([date], map: "idx_partner_login_log_date")
  @@map("partner_user_login_logs")
}

model PartnerUserActivitySession {
  id               String                   @id @default(uuid())
  partnerUserId    String
  sessionId        String                   @unique
  startTime        DateTime
  endTime          DateTime?
  totalEvents      Int                      @default(0)
  inactiveTimeMs   Int                      @default(0)
  pageViews        String[]                 @default([])
  userAgent        String?
  screenResolution String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  activityLogs     PartnerUserActivityLog[]
  partnerUser      PartnerUser              @relation("PartnerUserToActivitySessions", fields: [partnerUserId], references: [id], onDelete: Cascade)

  @@index([partnerUserId, startTime])
  @@index([sessionId])
  @@map("partner_user_activity_sessions")
}

model PartnerUserActivityLog {
  id        String                     @id @default(uuid())
  sessionId String
  timestamp DateTime
  eventType String
  pageUrl   String
  mouseX    Int?
  mouseY    Int?
  scrollPos Int?
  createdAt DateTime                   @default(now())
  session   PartnerUserActivitySession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([eventType])
  @@map("partner_user_activity_logs")
}

model PartnerUserInactivityAlert {
  id                  String      @id @default(uuid())
  partnerUserId       String
  inactiveTimeSeconds Int
  lastActivityTime    DateTime
  currentPage         String
  alertSentAt         DateTime    @default(now())
  createdAt           DateTime    @default(now())
  partnerUser         PartnerUser @relation("PartnerUserToInactivityAlerts", fields: [partnerUserId], references: [id], onDelete: Cascade)

  @@index([partnerUserId, alertSentAt])
  @@map("partner_user_inactivity_alerts")
}

model PaymentProviderLog {
  id                             String                        @id @default(uuid())
  paymentRequestId               String?
  paymentDisbursalTransactionId  String?
  paymentCollectionTransactionId String?
  provider                       String                        @db.VarChar(50)
  apiEndpoint                    String                        @db.VarChar(100)
  correlationId                  String                        @db.VarChar(100)
  requestHeaders                 Json?
  requestBody                    String?
  responseBody                   String?
  responseStatus                 Int?
  errorMessage                   String?
  createdAt                      DateTime                      @default(now())
  paymentCollectionTransaction   PaymentCollectionTransaction? @relation(fields: [paymentCollectionTransactionId], references: [id])
  paymentDisbursalTransaction    PaymentDisbursalTransaction?  @relation(fields: [paymentDisbursalTransactionId], references: [id])
  paymentRequest                 PaymentRequest?               @relation(fields: [paymentRequestId], references: [id])

  @@map("payment_provider_log")
}

model PartnerUserPasswordResetToken {
  id            String      @id @default(uuid())
  token         String      @unique
  partnerUserId String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  redirectLink  String      @db.VarChar(255)
  partner_users PartnerUser @relation(fields: [partnerUserId], references: [id], map: "partner_user_password_reset_tokens_userId_fkey")

  @@map("partner_user_password_reset_tokens")
}

model PartnerPermission {
  id                  Int                            @id @default(autoincrement())
  name                String                         @unique
  description         String?
  permission_group_id String?                        @db.VarChar(32)
  userPermissions     PartnerUserPermission[]
  primaryPermissions  PartnerUserPrimaryPermission[]

  @@map("partner_permissions")
}

model PartnerUserPermission {
  partnerUserId         String
  partnerPermissionId   Int
  partnerPermissionType PermissionType    @default(ALL)
  partnerPermission     PartnerPermission @relation(fields: [partnerPermissionId], references: [id])
  partnerUser           PartnerUser       @relation(fields: [partnerUserId], references: [id])

  @@id([partnerUserId, partnerPermissionId])
  @@index([partnerUserId], map: "idx_partner_user_perm_partner_user_id")
  @@index([partnerPermissionId], map: "idx_partner_user_perm_permission_id")
  @@map("partner_user_permissions")
}

model PartnerUserPrimaryPermission {
  partnerUserId       String            @unique
  partnerPermissionId Int
  partnerPermission   PartnerPermission @relation(fields: [partnerPermissionId], references: [id])
  partnerUser         PartnerUser       @relation("PrimaryPermissionRelation", fields: [partnerUserId], references: [id])

  @@map("partner_user_primary_permissions")
}

model PartnerUserBrandRole {
  partnerUserId String
  brandId       String
  roleId        Int
  brand         Brand       @relation(fields: [brandId], references: [id])
  user          PartnerUser @relation(fields: [partnerUserId], references: [id])
  role          PartnerRole @relation(fields: [roleId], references: [id])

  @@id([brandId, partnerUserId])
  @@index([partnerUserId, brandId], map: "idx_partner_brand_role_partner_brand")
  @@index([roleId], map: "idx_partner_brand_role_role_id")
  @@map("partner_user_brand_roles")
}

model PartnerUserGlobalRole {
  partnerUserId String
  roleId        Int
  user          PartnerUser @relation(fields: [partnerUserId], references: [id])
  role          PartnerRole @relation(fields: [roleId], references: [id])

  @@id([partnerUserId, roleId])
  @@map("partner_user_global_roles")
}

model BrandTheme {
  id                     String   @id @default(uuid())
  brandId                String   @unique
  primaryColor           String   @default("#FF6F00")
  secondaryColor         String   @default("#000000")
  backgroundColor        String   @default("#FDFDFD")
  surfaceColor           String   @default("#F8F9FA")
  primaryTextColor       String   @default("#212529")
  secondaryTextColor     String   @default("#495057")
  successColor           String   @default("#28A745")
  warningColor           String   @default("#FFC107")
  errorColor             String   @default("#DC3545")
  fontFamily             String   @default("system-ui")
  baseFontSize           Int      @default(16)
  roundedCorners         Boolean  @default(true)
  darkMode               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  primaryHoverColor      String   @default("#E65100")
  primaryFocusColor      String   @default("#FFAB40")
  primaryActiveColor     String   @default("#BF360C")
  primaryLightColor      String   @default("#FFE0B2")
  primaryContrastColor   String   @default("#FFFFFF")
  secondaryHoverColor    String   @default("#1C1C1C")
  secondaryFocusColor    String   @default("#333333")
  secondaryActiveColor   String   @default("#000000")
  secondaryLightColor    String   @default("#AAAAAA")
  secondaryContrastColor String   @default("#FFFFFF")
  surfaceTextColor       String   @default("#212529")
  backgroundTextColor    String   @default("#212529")
  brand                  Brand    @relation("BrandToTheme", fields: [brandId], references: [id], onDelete: Cascade)

  @@map("brand_themes")
}

model DigitapSomeTable {
  id                      String   @id @default(uuid())
  userId                  String
  brandId                 String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  panDetailsPlus          Json?
  mobilePrefill           Json?
  mobileAccountLookup     Json?
  pennyDropResponse       Json?
  intiateKycAuto          Json?
  submitOtp               Json?
  pennyDropStatus         Json?
  kycUnifiedv1GenerateUrl Json?
  kycUnifiedv1Details     Json?
  brand                   Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@map("digitap_some_table")
}

model BankAccountStatement {
  id                String             @id @default(uuid())
  userId            String
  userBankAccountId String
  filePrivateKey    String
  fromDate          DateTime?
  toDate            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  filePassword      String?            @db.VarChar(255)
  message           String?            @db.VarChar(255)
  isFraud           Boolean            @default(false) @map(" isFraud")
  fraudScore        Int                @default(0)
  user_bank_account UserBankAccount    @relation(fields: [userBankAccountId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartSomeTable     CartSomeTable[]
  FinboxSomeTable   FinboxSomeTable[]
  scoreMeSomeTable  ScoreMeSomeTable[]

  @@map("bank_account_statement")
}

model FinboxSomeTable {
  id                     String               @id @default(uuid())
  userId                 String
  userBankAccountId      String
  bankAccountStatementId String
  sessionResponse        Json?
  statementUploadSession Json?
  sessionId              String               @unique(map: "finbox_some_table_index_2")
  statementId            String?
  uploadedAt             DateTime             @default(now())
  createdAt              DateTime             @default(now())
  initiateProcessing     Json?
  bank_account_statement BankAccountStatement @relation(fields: [bankAccountStatementId], references: [id], onDelete: Cascade)
  user_bank_account      UserBankAccount      @relation(fields: [userBankAccountId], references: [id], onDelete: Cascade)
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("finbox_some_table")
}

model ScoreMeSomeTable {
  id                      String                @id @default(uuid())
  userId                  String
  userBankAccountId       String?
  uploadedAt              DateTime              @default(now())
  createdAt               DateTime              @default(now())
  referenceId             String?               @unique(map: "scoreme_some_table_index_2")
  uploadJson              Json?
  bsaReportJson           Json?
  bankAccountStatementId  String?
  bsaReportDownloadJson   Json?
  bsaReportXlsxPrivateKey String?               @db.VarChar(255)
  intiateKycAuto          Json?
  intiateKycDocumentId    String?               @db.VarChar(255)
  submitOtp               Json?
  bank_account_statement  BankAccountStatement? @relation(fields: [bankAccountStatementId], references: [id], onDelete: Cascade)
  user_bank_account       UserBankAccount?      @relation(fields: [userBankAccountId], references: [id], onDelete: Cascade)
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, userBankAccountId, bankAccountStatementId], map: "scoreme_some_table_index_3")
  @@unique([userId, intiateKycDocumentId], map: "scoreme_some_table_index_4")
  @@map("scoreme_some_table")
}

model CartSomeTable {
  id                      String               @id @default(uuid())
  userId                  String
  userBankAccountId       String
  uploadedAt              DateTime             @default(now())
  createdAt               DateTime             @default(now())
  referenceId             String               @unique(map: "cart_some_table_reference_id_unique")
  uploadJson              Json?
  bankAccountStatementId  String
  bsaReportDownloadJson   Json?
  bsaReportXlsxPrivateKey String?              @db.VarChar(255)
  bsaReportJson           Json?
  bankAccountStatement    BankAccountStatement @relation(fields: [bankAccountStatementId], references: [id], onDelete: Cascade)
  userBankAccount         UserBankAccount      @relation(fields: [userBankAccountId], references: [id], onDelete: Cascade)
  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, userBankAccountId, bankAccountStatementId], map: "cart_some_table_index_3")
  @@map("cart_some_table")
}

model EquifaxSomeTable {
  id                              String   @id @default(uuid())
  userId                          String
  braReportJson                   Json?
  documentUrl                     String?
  uploadedAt                      DateTime @default(now())
  createdAt                       DateTime @default(now())
  errorCode                       String?  @db.VarChar(10)
  errorMessage                    String?  @db.VarChar(255)
  encodedPdf                      Bytes?
  password                        String?  @default("1229Oct2025") @db.VarChar(64)
  cibil_pdf_key                   String?  @db.VarChar(255)
  cibil_json_gz_key               String?  @db.VarChar(255)
  generated_cibil_report_html_key String?  @db.VarChar(255)
  metadata                        Json?
  user                            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("equifax_some_table")
}

model CirProV2SomeTable {
  id                              String   @id @default(uuid())
  userId                          String
  rawReportJson                   Json?
  reportDocumentUrl               String?
  uploadedAt                      DateTime @default(now())
  createdAt                       DateTime @default(now())
  errorCode                       String?  @db.VarChar(10)
  errorMessage                    String?  @db.VarChar(255)
  formattedReport                 String?
  cibil_html_key                  String?  @db.VarChar(255)
  cibil_json_gz_key               String?  @db.VarChar(255)
  generated_cibil_report_html_key String?  @db.VarChar(255)
  metadata                        Json?
  user                            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cirprov2_some_table")
}

model SignDeskSomeTable {
  id                       String                 @id @default(uuid())
  userId                   String
  loanId                   String
  loanAgreementsId         String
  responseJson             Json?
  uploadedAt               DateTime               @default(now())
  createdAt                DateTime               @default(now())
  loanAgreementReferenceId String
  documentId               String?
  callbackResponse         Json?
  manualSyncResponse       Json?
  pdfBlob                  Bytes?
  workflowUrl              String?
  loanAgreementReference   LoanAgreementReference @relation(fields: [loanAgreementReferenceId], references: [id], onDelete: SetNull)
  loanAgreement            LoanAgreement          @relation(fields: [loanAgreementsId], references: [id])
  loan                     Loan                   @relation(fields: [loanId], references: [id])
  user                     User                   @relation(fields: [userId], references: [id])

  @@map("signdesk_some_table")
}

model UserBankAccount {
  id                   String                         @id @default(uuid())
  userId               String
  accountHolderName    String?
  accountNumber        String?
  ifscCode             String?
  bankName             String?
  accountType          String
  isVerified           Boolean                        @default(false)
  verificationMethod   user_bank_verification_method?
  verificationStatus   user_bank_verification_status  @default(PENDING)
  verifiedAt           DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @default(now())
  userDataStatus       user_data_status               @default(NOT_VERIFIED)
  bankAddress          String?                        @db.VarChar(255)
  isPrimary            Boolean                        @default(false)
  pennyDropResponse    Json?
  pennyDropStatus      Json?
  pennyVerifiedName    String?                        @db.VarChar(255)
  BankAccountStatement BankAccountStatement[]
  cartSomeTable        CartSomeTable[]
  FinboxSomeTable      FinboxSomeTable[]
  pennyDropLogs        penny_drop_log[]
  scoreMeSomeTable     ScoreMeSomeTable[]
  user                 User                           @relation(fields: [userId], references: [id], map: "user_bank_account_user_id_fkey")

  @@unique([userId, accountNumber], map: "user_bank_account_index_2")
  @@map("user_bank_account")
}

model AlternateAddress {
  id               String            @id @default(uuid())
  userId           String
  address          String
  city             String
  state            String
  pincode          String
  country          String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now())
  residenceType    ResidenceTypeEnum @default(OWNED)
  filePrivateKey   String?
  addressProofType AddressProofEnum?
  isActive         Boolean           @default(true)
  isDisabled       Boolean           @default(false)
  remarks          String?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alternate_addresses")
}

model Payslip {
  id             String     @id @default(uuid())
  userId         String
  employmentId   String
  month          Int
  year           Int
  filePrivateKey String
  fileName       String?
  uploadedAt     DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  filePassword   String?    @db.VarChar(255)
  employment     Employment @relation(fields: [employmentId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, employmentId, month, year], name: "unique_payslip_per_month")
  @@map("payslips")
}

model AlternatePhoneNumber {
  id               String            @id @default(uuid())
  userId           String
  phone            String            @db.VarChar(20)
  label            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now())
  isVerified       Boolean           @default(false)
  verifiedAt       DateTime?
  name             String?
  otp              String?           @db.VarChar(6)
  relationship     RelationshipEnum?
  verificationType VerificationType  @default(OTP)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone], map: "alternate_phone_numbers_index_2")
  @@map("alternate_phone_numbers")
}

model CallMeRequest {
  id          String    @id @default(uuid())
  userId      String
  brandId     String
  message     String
  createdAt   DateTime  @default(now())
  phoneNumber String    @db.VarChar(15)
  isResolved  Boolean   @default(false)
  updatedAt   DateTime
  resolvedAt  DateTime?
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("call_me_requests")
}

model previous_employments {
  id                String    @id @default(uuid())
  userId            String
  brandId           String
  customerName      String
  uanNumber         String?   @db.VarChar(12)
  memberId          String?   @db.VarChar(50)
  joiningDate       DateTime?
  exitDate          DateTime?
  guardianName      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  establishmentName String?   @db.VarChar(255)
  brand             Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PanAadhaarVerification {
  id               String             @id @default(uuid())
  documentId       String             @unique
  httpResponseCode Int
  resultCode       Int
  requestId        String
  clientRefNum     String
  pan              String
  panType          String
  fullname         String
  firstName        String
  middleName       String
  lastName         String
  gender           String
  aadhaarNumber    String
  aadhaarLinked    Boolean
  dob              DateTime
  mobile           String?
  email            String?
  createdAt        DateTime           @default(now())
  address          PanAadhaarAddress?
  document         Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("pan_aadhaar_verification")
}

model MobileToPanVerification {
  id             String    @id @default(uuid())
  userId         String
  brandId        String
  mobile         String
  firstName      String
  lastName       String?
  pan            String?
  fullName       String?
  gender         String?
  dateOfBirth    DateTime?
  profilePicUrl  String?
  responseCode   Int?
  message        String?
  status         Int?
  timestamp      DateTime
  transactionId  String
  statusCode     Int
  statusText     String
  success        Boolean
  packageVersion String?
  msg            String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  brand          Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId], map: "unique_user_brand")
  @@map("mobile_to_pan_verifications")
}

model PanAadhaarAddress {
  id             String                 @id @default(uuid())
  verificationId String                 @unique
  buildingName   String
  locality       String
  streetName     String
  pincode        String
  city           String
  state          String
  country        String
  createdAt      DateTime               @default(now())
  verification   PanAadhaarVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@map("pan_aadhaar_address")
}

model User {
  id                                                  String                            @id @default(uuid())
  email                                               String?                           @db.VarChar(255)
  phoneNumber                                         String?                           @db.VarChar(13)
  createdAt                                           DateTime                          @default(now())
  updatedAt                                           DateTime                          @default(now())
  onboardingStep                                      Int                               @default(1)
  isEmailVerified                                     Boolean                           @default(false)
  brandId                                             String?
  isPhoneVerified                                     Boolean?                          @default(false)
  googleId                                            String?                           @db.VarChar(255)
  isWhatsappVerified                                  Boolean                           @default(false)
  emailVerifiedAt                                     DateTime?
  phoneVerifiedAt                                     DateTime?
  whatsappVerifiedAt                                  DateTime?
