  master_pincodes  master_pincodes[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model master_districts {
  id              Int               @id(map: "master_cities_pkey") @default(autoincrement())
  name            String            @db.VarChar(100)
  stateId         Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now())
  master_states   master_states     @relation(fields: [stateId], references: [id], onDelete: Cascade, map: "master_cities_stateId_fkey")
  master_pincodes master_pincodes[]

  @@unique([name, stateId], map: "master_cities_name_stateId_key")
  @@index([stateId], map: "master_cities_stateId_idx")
}

