          "description": "IFSC must exist in approved bank list",
          "rejectionReasonId": "f72ab07f-7081-4ac6-919a-794e15babcd7"
        },
        "10_nameMatchPanBank": {
          "paramNo": 10,
          "paramName": "Name Match: PAN vs Bank Account",
