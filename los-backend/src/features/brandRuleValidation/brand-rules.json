          "min": 21,
          "max": 55,
          "unit": "years",
          "description": "Applicant age must be between 21 and 55",
          "rejectionReasonId": "a1738206-26bc-4838-b071-05280293a44c"
        },
        "8_pinCode": {
          "paramNo": 8,
