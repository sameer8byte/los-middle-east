<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8" />
  <title><%= subject %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>

<body style="margin:0; padding:0; background:#f4f6f8; font-family: Arial, Helvetica, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
    <tr>
      <td align="center" style="padding:32px 16px;">

        <!-- Card -->
        <table width="600" cellpadding="0" cellspacing="0" role="presentation" style="background:#ffffff; border-radius:10px; overflow:hidden;">

          <!-- Header with Logo -->
          <tr>
            <td align="center" style="padding:24px; background:#0f172a;">
              <img src="<%= brand_logo %>" alt="<%= brand_name %>" height="40" style="display:block; max-width:160px;" />
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:32px; text-align:left;">
              <h1 style="margin:0 0 16px; font-size:24px; color:#111827;">
                <%= headline %>
              </h1>

              <p style="margin:0 0 20px; font-size:16px; line-height:1.6; color:#4b5563;">
                <%- body_content %>
              </p>

              <!-- CTA -->
              <div style="text-align:center; margin-top:24px;">
                <a href="<%= cta_link %>" style="background:#2563eb; color:#ffffff; padding:14px 28px;
                    text-decoration:none; font-size:16px; font-weight:600;
                    border-radius:6px; display:inline-block;">
                  <%= cta_text %>
                </a>
              </div>

              <!-- Trust / urgency -->
              <p style="margin-top:20px; font-size:14px; color:#6b7280; text-align:center;">
                Takes less than 2 minutes • No paperwork • Secure
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px; background:#f9fafb; font-size:12px; color:#6b7280; text-align:center;">
              <p style="margin:0 0 8px;">
                You’re receiving this because you started an application with <%= brand_name %>.
              </p>
              <p style="margin:0;">
                © <%= year %> <%= brand_name %>. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>

</html>