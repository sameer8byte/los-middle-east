<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Loan Application Acknowledgment</title>
  <style>
    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      background-color: #fff;
      color: #333;
      margin: 40px;
    }

    .document-header {
      text-align: center;
      margin-bottom: 40px;
      border-bottom: 2px solid #333;
      padding-bottom: 15px;
    }

    .document-header img {
      max-height: 80px;
      margin-bottom: 10px;
    }

    .document-header h1 {
      font-size: 24px;
      margin: 0;
      text-transform: uppercase;
    }

    .section-title {
      font-size: 20px;
      margin-top: 40px;
      margin-bottom: 15px;
      border-bottom: 1px solid #999;
      padding-bottom: 5px;
    }

    .info-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
      font-size: 15px;
    }

    .info-table th, .info-table td {
      text-align: left;
      padding: 10px;
      border: 1px solid #ddd;
    }

    .paragraph {
      margin: 20px 0;
      font-size: 16px;
      line-height: 1.5;
    }

    .footer {
      margin-top: 50px;
      font-size: 12px;
      color: #777;
      text-align: center;
    }
  </style>
</head>
<body>

  <div class="document-header">
    <% if (brand && brand.logoUrl) { %>
      <img src="<%= brand.logoUrl %>" alt="<%= brand.name %> Logo">
    <% } %>
    <h1>Loan Application Acknowledgment</h1>
  </div>

  <div class="paragraph">
    <p>Dear <strong><%= user.firstName %> <%= user.lastName %></strong>,</p>
    <p>We acknowledge the receipt of your loan application. Your application has been successfully submitted and is currently under review. You will be notified of the status once our verification and assessment process is complete.</p>
  </div>

  <div class="section-title">Application Details</div>

  <table class="info-table">
    <tr>
      <th>Application ID</th>
      <td><%= loan.applicationId %></td>
    </tr>
    <tr>
      <th>Loan Amount</th>
      <td>₹<%= loan.amount.toLocaleString() %></td>
    </tr>
    <tr>
      <th>Tenure</th>
      <td><%= loan.tenure %> days</td>
    </tr>
    <tr>
      <th>Applied On</th>
      <td><%= loan.appliedDate %></td>
    </tr>
    <% if (loan.purpose) { %>
      <tr>
        <th>Purpose</th>
        <td><%= loan.purpose %></td>
      </tr>
    <% } %>
  </table>

  <div class="paragraph">
    <p>If you have any questions or need further assistance, please feel free to contact our customer support team.</p>
  </div>

  <div class="footer">
    &copy; <%= new Date().getFullYear() %> <%= brand.name || 'Our Lending Platform' %>. All rights reserved.
  </div>

</body>
</html>
