<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>OTP Verification</title>
  <style>
    body {
      background-color: #f5f5f5;
      margin: 0;
      padding: 0;
      font-family: "Inter", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #111;
    }

    .container {
      max-width: 440px;
      margin: 40px auto;
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      padding: 32px 28px;
      box-sizing: border-box;
    }

    .brand {
      text-align: center;
      font-size: 22px;
      font-weight: 600;
      color: #000;
      margin-bottom: 20px;
      letter-spacing: 0.5px;
    }

    .message {
      text-align: center;
      font-size: 15px;
      line-height: 1.6;
      color: #333;
      margin-bottom: 28px;
    }

    .otp-wrapper {
      text-align: center;
      margin-bottom: 24px;
    }

    .otp {
      display: inline-block;
      font-size: 34px;
      font-weight: 700;
      letter-spacing: 8px;
      color: #000;
      background: #fafafa;
      padding: 12px 24px;
      border-radius: 6px;
      border: 1px solid #e5e5e5;
    }

    .note {
      font-size: 13px;
      text-align: center;
      color: #555;
      line-height: 1.5;
    }

    .footer {
      text-align: center;
      font-size: 12px;
      color: #888;
      margin-top: 30px;
      border-top: 1px solid #eee;
      padding-top: 14px;
    }

    @media (max-width: 480px) {
      .container {
        margin: 20px;
        padding: 24px 18px;
      }
      .otp {
        font-size: 28px;
        letter-spacing: 6px;
        padding: 10px 18px;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="brand"><%= brandName %></div>

    <p class="message">
      Use the following One-Time Password (OTP) to complete your verification:
    </p>

    <div class="otp-wrapper">
      <div class="otp"><%= otp %></div>
    </div>

    <p class="note">
      This code is valid for <strong><%= expiryTime %></strong> minutes.<br />
      Do not share it with anyone for your security.
    </p>

    <div class="footer">
      &copy; <%= year %> <%= brandName %>. All rights reserved.
    </div>
  </div>
</body>
</html>
